#!/usr/bin/env fish
# Nepes Dark — fish shell color theme
# Source this file: source nepes-dark.fish

# Syntax highlighting
set -U fish_color_normal DCD8D4
set -U fish_color_command 3A9BA5
set -U fish_color_keyword 5C8CFF
set -U fish_color_quote 3DDC84
set -U fish_color_redirection B6B0AC
set -U fish_color_end FEA413
set -U fish_color_error FF5C5C
set -U fish_color_param A274C3
set -U fish_color_comment 8D847B
set -U fish_color_selection --background=3E3A38
set -U fish_color_search_match --background=2E4C7A
set -U fish_color_operator E8C55A
set -U fish_color_escape FEA413
set -U fish_color_autosuggestion 8D847B
set -U fish_color_cancel FF5C5C
set -U fish_color_cwd 5C8CFF
set -U fish_color_user 3DDC84
set -U fish_color_host 3A9BA5
set -U fish_color_valid_path --underline

# Pager
set -U fish_pager_color_progress B6B0AC
set -U fish_pager_color_prefix 3A9BA5 --bold
set -U fish_pager_color_completion DCD8D4
set -U fish_pager_color_description 8D847B
set -U fish_pager_color_selected_background --background=3E3A38

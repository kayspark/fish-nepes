#!/usr/bin/env fish
# Nepes Light — fish shell color theme
# Source this file: source nepes-light.fish

# Syntax highlighting
set -U fish_color_normal 1C1C1E
set -U fish_color_command 2D7A82
set -U fish_color_keyword 23438E
set -U fish_color_quote 2A8030
set -U fish_color_redirection 3A3A3E
set -U fish_color_end D08A10
set -U fish_color_error C4181F
set -U fish_color_param 7A4FA0
set -U fish_color_comment 707079
set -U fish_color_selection --background=D8D7D7
set -U fish_color_search_match --background=B8D0F0
set -U fish_color_operator 866E1C
set -U fish_color_escape D08A10
set -U fish_color_autosuggestion 707079
set -U fish_color_cancel C4181F
set -U fish_color_cwd 23438E
set -U fish_color_user 2A8030
set -U fish_color_host 2D7A82
set -U fish_color_valid_path --underline

# Pager
set -U fish_pager_color_progress 3A3A3E
set -U fish_pager_color_prefix 2D7A82 --bold
set -U fish_pager_color_completion 1C1C1E
set -U fish_pager_color_description 707079
set -U fish_pager_color_selected_background --background=D8D7D7
